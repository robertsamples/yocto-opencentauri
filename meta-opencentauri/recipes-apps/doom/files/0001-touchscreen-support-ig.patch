+// ---------- Touch zones ----------
+
+enum {
+    ZONE_NONE = 0,
+    ZONE_MOVE,
+    ZONE_AIM,
+    ZONE_BTN_ESC,
+    ZONE_BTN_USE,
+    ZONE_BTN_FIRE,
+    ZONE_BTN_PREV_WEAPON,
+    ZONE_BTN_NEXT_WEAPON,
+};
+
+// ---------- Touch slot state ----------
+
+typedef struct {
+    int active;
+    int zone;
+    int start_px, start_py;
+    int cur_px, cur_py;
+    int prev_px, prev_py;
+    int has_prev;
+    uint32_t start_time_ms;
+    int moved;
+    int key_fwd, key_back, key_left, key_right;
+} touch_slot_t;
+
+static touch_slot_t touch_slots[MAX_TOUCH_SLOTS];
+static int current_slot = 0;
+static int fire_release_pending = 0;
+
+static int ts_x_min = 0, ts_x_max = 1;
+static int ts_y_min = 0, ts_y_max = 1;
+
+static int kb_fd = -1;
+static int ts_fd = -1;
+static int ts_is_multitouch = 0;  // 1 = Protocol B (ABS_MT_*), 0 = single-touch (ABS_X/Y)
+
+static int shiftdown = 0;
+
+int vanilla_keyboard_mapping = 1;
+
