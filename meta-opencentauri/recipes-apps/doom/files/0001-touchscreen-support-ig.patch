+// ---------- Tuning constants ----------
+
+#define TOUCH_DEADZONE_FRAC  0.03f
+#define TOUCH_TURN_SCALE     3
+#define TOUCH_FWD_SCALE      1
+#define TAP_MAX_TIME_MS      200
