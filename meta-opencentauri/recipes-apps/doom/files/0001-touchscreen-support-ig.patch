+    '{', '|', '}', '~', 127
+};
+
+// ---------- Helpers ----------
+
+static uint32_t now_ms(void)
+{
+    struct timespec ts;
+    clock_gettime(CLOCK_MONOTONIC, &ts);
+    return (uint32_t)(ts.tv_sec * 1000 + ts.tv_nsec / 1000000);
+}
+
+static int map_coord(int v, int v_min, int v_max, int fb_max)
+{
+    if (v_max <= v_min)
+        return 0;
+    if (v < v_min) v = v_min;
+    if (v > v_max) v = v_max;
+    double t = (double)(v - v_min) / (double)(v_max - v_min);
+    int px = (int)(t * fb_max + 0.5);
+    if (px < 0) px = 0;
+    if (px > fb_max) px = fb_max;
+    return px;
+}
+
+static int test_bit(int bit, const unsigned long *array)
+{
+    return (array[bit / (sizeof(long) * 8)] >> (bit % (sizeof(long) * 8))) & 1;
+}
+
+static int classify_zone(int px, int py, int fbw, int fbh)
+{
+    float fx = (float)px / fbw;
+    float fy = (float)py / fbh;
+
+    if (fy < ZONE_TOP_FRAC) {
+        if (fx < BTN_W_FRAC)
+            return ZONE_BTN_ESC;
+        if (fx > 1.0f - 2 * BTN_W_FRAC && fx <= 1.0f - BTN_W_FRAC)
+            return ZONE_BTN_PREV_WEAPON;
+        if (fx > 1.0f - BTN_W_FRAC)
+            return ZONE_BTN_NEXT_WEAPON;
+        return (fx < ZONE_SPLIT_X) ? ZONE_MOVE : ZONE_AIM;
+    }
+
+    if (fy > ZONE_BOTTOM_FRAC) {
+        if (fx < BTN_W_FRAC + 0.05f)
+            return ZONE_BTN_USE;
+        if (fx > 1.0f - BTN_W_FRAC - 0.05f)
+            return ZONE_BTN_FIRE;
+        return (fx < ZONE_SPLIT_X) ? ZONE_MOVE : ZONE_AIM;
+    }
+
+    if (fx < ZONE_SPLIT_X)
+        return ZONE_MOVE;
+    return ZONE_AIM;
+}
+
+static const char *zone_name(int zone)
+{
+    switch (zone) {
+    case ZONE_MOVE:            return "MOVE";
+    case ZONE_AIM:             return "AIM";
+    case ZONE_BTN_ESC:         return "ESC";
+    case ZONE_BTN_USE:         return "USE";
+    case ZONE_BTN_FIRE:        return "FIRE";
+    case ZONE_BTN_PREV_WEAPON: return "PREV_WPN";
+    case ZONE_BTN_NEXT_WEAPON: return "NEXT_WPN";
+    default:                   return "NONE";
+    }
+}
+
+static void post_key(int doom_key, int down)
+{
+    event_t event;
+    event.type = down ? ev_keydown : ev_keyup;
+    event.data1 = doom_key;
+    event.data2 = 0;
+    event.data3 = 0;
+    event.data4 = 0;
+    D_PostEvent(&event);
+}
+
+static void release_movement_keys(touch_slot_t *s)
+{
+    if (s->key_fwd)   { post_key(KEY_UPARROW, 0);   s->key_fwd = 0; }
+    if (s->key_back)  { post_key(KEY_DOWNARROW, 0);  s->key_back = 0; }
+    if (s->key_left)  { post_key(KEY_STRAFE_L, 0);   s->key_left = 0; }
+    if (s->key_right) { post_key(KEY_STRAFE_R, 0);   s->key_right = 0; }
+}
+
+static void finger_up(touch_slot_t *s)
+{
+    if (!s->active)
+        return;
+    printf("touch: up zone=%s moved=%d\n", zone_name(s->zone), s->moved);
+    if (s->zone == ZONE_AIM && !s->moved) {
+        uint32_t elapsed = now_ms() - s->start_time_ms;
+        if (elapsed < TAP_MAX_TIME_MS) {
+            printf("touch: tap -> ENTER\n");
+            post_key(KEY_ENTER, 1);
+            fire_release_pending = 1;
+        }
+    }
+    release_movement_keys(s);
+    if (s->zone == ZONE_BTN_ESC)
+        post_key(KEY_ESCAPE, 0);
+    else if (s->zone == ZONE_BTN_USE)
+        post_key(KEY_USE, 0);
+    else if (s->zone == ZONE_BTN_FIRE)
+        post_key(KEY_FIRE, 0);
+    s->active = 0;
+    s->zone = ZONE_NONE;
+}
+
+// ---------- Device detection ----------
+
+static int detect_keyboard(void)
+{
+    char path[64];
+    unsigned long evbits[(EV_MAX + 1) / (sizeof(long) * 8) + 1];
+    unsigned long keybits[(KEY_MAX + 1) / (sizeof(long) * 8) + 1];
+
+    for (int i = 0; i < MAX_EVDEV_SCAN; i++) {
+        snprintf(path, sizeof(path), "/dev/input/event%d", i);
+        int fd = open(path, O_RDONLY | O_NONBLOCK);
+        if (fd < 0)
+            continue;
+
+        memset(evbits, 0, sizeof(evbits));
+        memset(keybits, 0, sizeof(keybits));
+
+        if (ioctl(fd, EVIOCGBIT(0, sizeof(evbits)), evbits) < 0) {
+            close(fd);
+            continue;
+        }
+        if (!test_bit(EV_KEY, evbits)) {
+            close(fd);
+            continue;
+        }
+        if (ioctl(fd, EVIOCGBIT(EV_KEY, sizeof(keybits)), keybits) < 0) {
+            close(fd);
+            continue;
+        }
+
+        // A keyboard has letter keys
+        if (test_bit(KEY_A, keybits) && test_bit(KEY_Z, keybits)) {
+            printf("I_InitInput: Found keyboard at %s\n", path);
+            return fd;
+        }
+
+        close(fd);
+    }
+    return -1;
+}
+
+static int detect_touchscreen(int *is_multitouch)
+{
+    char path[64];
+    unsigned long evbits[(EV_MAX + 1) / (sizeof(long) * 8) + 1];
+    unsigned long absbits[(ABS_MAX + 1) / (sizeof(long) * 8) + 1];
+    int fallback_fd = -1;
+
+    *is_multitouch = 0;
+
+    for (int i = 0; i < MAX_EVDEV_SCAN; i++) {
+        snprintf(path, sizeof(path), "/dev/input/event%d", i);
+        int fd = open(path, O_RDONLY | O_NONBLOCK);
+        if (fd < 0)
+            continue;
+
+        memset(evbits, 0, sizeof(evbits));
+        memset(absbits, 0, sizeof(absbits));
+
+        if (ioctl(fd, EVIOCGBIT(0, sizeof(evbits)), evbits) < 0) {
+            close(fd);
+            continue;
+        }
+        if (!test_bit(EV_ABS, evbits)) {
+            close(fd);
+            continue;
+        }
+        if (ioctl(fd, EVIOCGBIT(EV_ABS, sizeof(absbits)), absbits) < 0) {
+            close(fd);
+            continue;
+        }
+
+        // Prefer multitouch (Protocol B)
+        if (test_bit(ABS_MT_POSITION_X, absbits) &&
+            test_bit(ABS_MT_POSITION_Y, absbits)) {
+            printf("I_InitInput: Found multitouch screen at %s\n", path);
+            *is_multitouch = 1;
+            if (fallback_fd >= 0)
+                close(fallback_fd);
+            return fd;
+        }
+
+        // Accept single-touch / tablet (ABS_X + ABS_Y) as fallback
+        if (test_bit(ABS_X, absbits) && test_bit(ABS_Y, absbits) &&
+            fallback_fd < 0) {
+            fallback_fd = fd;
+            continue;  // keep scanning for multitouch
+        }
+
+        close(fd);
+    }
+
+    if (fallback_fd >= 0) {
+        // Re-read the path for logging
+        printf("I_InitInput: Found single-touch device (fd %d)\n", fallback_fd);
+        *is_multitouch = 0;
+    }
+    return fallback_fd;
+}
+
+// ---------- Shutdown ----------
+
+static void evdev_shutdown(void)
+{
+    for (int i = 0; i < MAX_TOUCH_SLOTS; i++) {
+        if (touch_slots[i].active)
+            release_movement_keys(&touch_slots[i]);
+    }
+    if (kb_fd >= 0) { close(kb_fd); kb_fd = -1; }
+    if (ts_fd >= 0) { close(ts_fd); ts_fd = -1; }
+}
+
+// ---------- Keyboard reading ----------
+
+static unsigned char get_typed_char(unsigned char doom_key)
+{
+    if (shiftdown > 0) {
+        if (doom_key < sizeof(shiftxform))
+            return shiftxform[(unsigned)doom_key];
+        return 0;
+    }
+    return doom_key;
+}
+
+static void read_keyboard(void)
+{
+    struct input_event ev;
+
+    while (kb_fd >= 0 && read(kb_fd, &ev, sizeof(ev)) == (int)sizeof(ev)) {
+        if (ev.type != EV_KEY || ev.code >= 256)
+            continue;
+
+        if (ev.code == KEY_LEFTSHIFT || ev.code == KEY_RIGHTSHIFT) {
+            if (ev.value == 1)
+                shiftdown++;
+            else if (ev.value == 0 && shiftdown > 0)
+                shiftdown--;
+        }
+
+        unsigned char doom_key = evdev_to_doom[ev.code];
+        if (doom_key == 0)
+            continue;
+
+        if (ev.value == 1) {
+            event_t event;
+            event.type = ev_keydown;
+            event.data1 = doom_key;
+            event.data2 = get_typed_char(doom_key);
+            event.data3 = 0;
+            event.data4 = 0;
+            D_PostEvent(&event);
+        } else if (ev.value == 0) {
+            event_t event;
+            event.type = ev_keyup;
+            event.data1 = doom_key;
+            event.data2 = 0;
+            event.data3 = 0;
+            event.data4 = 0;
+            D_PostEvent(&event);
+        }
+    }
+}
+
+// ---------- Touchscreen reading ----------
+
+static void read_touchscreen(void)
+{
+    struct input_event ev;
+    int fbw = fb.xres;
+    int fbh = fb.yres;
+
+    if (fbw <= 0 || fbh <= 0)
+        return;
+
+    int deadzone_px_x = (int)(TOUCH_DEADZONE_FRAC * fbw);
+    int deadzone_px_y = (int)(TOUCH_DEADZONE_FRAC * fbh);
+    int tap_dist_px = (int)(TAP_MAX_DIST_FRAC * fbw);
+
+    int aim_dx = 0, aim_dy = 0;
+
+    if (fire_release_pending) {
+        post_key(KEY_ENTER, 0);
+        fire_release_pending = 0;
+    }
+
+    // Phase 1: Read raw evdev events, update slot state
+    while (ts_fd >= 0 && read(ts_fd, &ev, sizeof(ev)) == (int)sizeof(ev)) {
+        if (ev.type == EV_ABS) {
+            if (ts_is_multitouch) {
+                // Protocol B multitouch
+                if (ev.code == ABS_MT_SLOT) {
+                    if (ev.value >= 0 && ev.value < MAX_TOUCH_SLOTS)
+                        current_slot = ev.value;
+                } else if (ev.code == ABS_MT_TRACKING_ID) {
+                    touch_slot_t *s = &touch_slots[current_slot];
+                    if (ev.value >= 0) {
+                        s->active = 1;
+                        s->zone = ZONE_NONE;
+                        s->start_px = -1;
+                        s->start_py = -1;
+                        s->has_prev = 0;
+                        s->start_time_ms = now_ms();
+                        s->moved = 0;
+                        s->key_fwd = s->key_back = s->key_left = s->key_right = 0;
+                    } else {
+                        finger_up(s);
+                    }
+                } else if (ev.code == ABS_MT_POSITION_X) {
+                    touch_slots[current_slot].cur_px = ev.value;
+                } else if (ev.code == ABS_MT_POSITION_Y) {
+                    touch_slots[current_slot].cur_py = ev.value;
+                }
+            } else {
+                // Single-touch (ABS_X / ABS_Y) — always slot 0
+                if (ev.code == ABS_X) {
+                    touch_slots[0].cur_px = ev.value;
+                } else if (ev.code == ABS_Y) {
+                    touch_slots[0].cur_py = ev.value;
+                }
+            }
+        } else if (ev.type == EV_KEY && !ts_is_multitouch) {
+            // Single-touch: BTN_LEFT or BTN_TOUCH = finger down/up
+            if (ev.code == BTN_LEFT || ev.code == BTN_TOUCH) {
+                touch_slot_t *s = &touch_slots[0];
+                if (ev.value == 1 && !s->active) {
+                    s->active = 1;
+                    s->zone = ZONE_NONE;
+                    s->start_px = -1;
+                    s->start_py = -1;
+                    s->has_prev = 0;
+                    s->start_time_ms = now_ms();
+                    s->moved = 0;
+                    s->key_fwd = s->key_back = s->key_left = s->key_right = 0;
+                } else if (ev.value == 0) {
+                    finger_up(s);
+                }
+            }
+        }
+        // Don't break at SYN_REPORT — drain all pending events so we
+        // don't fall behind when events arrive faster than the tic rate.
+    }
+
+    // Phase 2: Process touch state into Doom events
+    for (int i = 0; i < MAX_TOUCH_SLOTS; i++) {
+        touch_slot_t *s = &touch_slots[i];
+        if (!s->active)
+            continue;
+
+        int px = map_coord(s->cur_px, ts_x_min, ts_x_max, fbw - 1);
+        int py = map_coord(s->cur_py, ts_y_min, ts_y_max, fbh - 1);
+
+        // Assign zone on first position update after touch-down
+        if (s->start_px < 0) {
+            s->start_px = px;
+            s->start_py = py;
+            s->zone = classify_zone(px, py, fbw, fbh);
+            printf("touch: slot=%d zone=%s pos=(%d,%d) fb=(%dx%d)\n",
+                   i, zone_name(s->zone), px, py, fbw, fbh);
+
+            if (s->zone == ZONE_BTN_ESC)
+                post_key(KEY_ESCAPE, 1);
+            else if (s->zone == ZONE_BTN_USE)
+                post_key(KEY_USE, 1);
+            else if (s->zone == ZONE_BTN_FIRE)
+                post_key(KEY_FIRE, 1);
+            else if (s->zone == ZONE_BTN_PREV_WEAPON)
+                post_key('-', 1);
+            else if (s->zone == ZONE_BTN_NEXT_WEAPON)
+                post_key('=', 1);
+        }
+
+        // Movement zone: virtual D-pad
+        if (s->zone == ZONE_MOVE) {
+            int dx = px - s->start_px;
+            int dy = py - s->start_py;
+
+            int want_fwd   = (dy < -deadzone_px_y);
+            int want_back  = (dy >  deadzone_px_y);
+            int want_left  = (dx < -deadzone_px_x);
+            int want_right = (dx >  deadzone_px_x);
+
+            if (want_fwd && !s->key_fwd)     { post_key(KEY_UPARROW, 1);   s->key_fwd = 1; }
+            if (!want_fwd && s->key_fwd)     { post_key(KEY_UPARROW, 0);   s->key_fwd = 0; }
+            if (want_back && !s->key_back)   { post_key(KEY_DOWNARROW, 1); s->key_back = 1; }
+            if (!want_back && s->key_back)   { post_key(KEY_DOWNARROW, 0); s->key_back = 0; }
+            if (want_left && !s->key_left)   { post_key(KEY_STRAFE_L, 1);  s->key_left = 1; }
+            if (!want_left && s->key_left)   { post_key(KEY_STRAFE_L, 0);  s->key_left = 0; }
+            if (want_right && !s->key_right) { post_key(KEY_STRAFE_R, 1);  s->key_right = 1; }
+            if (!want_right && s->key_right) { post_key(KEY_STRAFE_R, 0);  s->key_right = 0; }
+        }
+
+        // Aim zone: accumulate mouse deltas
+        if (s->zone == ZONE_AIM) {
+            if (s->has_prev) {
+                aim_dx += px - s->prev_px;
+                aim_dy += py - s->prev_py;
+            }
+            s->prev_px = px;
+            s->prev_py = py;
+            s->has_prev = 1;
+
+            int total = abs(px - s->start_px) + abs(py - s->start_py);
+            if (total > tap_dist_px)
+                s->moved = 1;
+        }
+    }
+
+    // Post accumulated aim as a single mouse event
+    if (aim_dx != 0 || aim_dy != 0) {
+        event_t event;
+        event.type = ev_mouse;
+        event.data1 = 0;
+        event.data2 = aim_dx * TOUCH_TURN_SCALE;
+        event.data3 = -aim_dy * TOUCH_FWD_SCALE;
+        event.data4 = 0;
+        D_PostEvent(&event);
+    }
+}
+
+// ---------- Public interface ----------
+
+void I_GetEvent(void)
+{
+    read_keyboard();
+    read_touchscreen();
+}
+
+void I_StartTic(void)
+{
+    I_GetEvent();
+}
+
+int I_InitInput(void)
+{
+    memset(touch_slots, 0, sizeof(touch_slots));
+
+    int p = M_CheckParmWithArgs("-evdev_kb", 1);
+    if (p > 0) {
+        kb_fd = open(myargv[p + 1], O_RDONLY | O_NONBLOCK);
+        if (kb_fd < 0)
+            fprintf(stderr, "I_InitInput: Could not open keyboard device %s\n",
+                    myargv[p + 1]);
+        else
+            printf("I_InitInput: Using keyboard at %s\n", myargv[p + 1]);
+    } else {
+        kb_fd = detect_keyboard();
+    }
+
+    if (kb_fd < 0)
+        fprintf(stderr, "I_InitInput: No keyboard found (touch-only mode)\n");
+
+    p = M_CheckParmWithArgs("-evdev_ts", 1);
+    if (p > 0) {
+        ts_fd = open(myargv[p + 1], O_RDONLY | O_NONBLOCK);
+        if (ts_fd < 0)
+            fprintf(stderr, "I_InitInput: Could not open touchscreen device %s\n",
+                    myargv[p + 1]);
+        else
+            printf("I_InitInput: Using touchscreen at %s\n", myargv[p + 1]);
+    } else {
+        ts_fd = detect_touchscreen(&ts_is_multitouch);
+    }
+
+    if (ts_fd >= 0) {
+        struct input_absinfo absinfo;
+        int abs_x_code = ts_is_multitouch ? ABS_MT_POSITION_X : ABS_X;
+        int abs_y_code = ts_is_multitouch ? ABS_MT_POSITION_Y : ABS_Y;
+        if (ioctl(ts_fd, EVIOCGABS(abs_x_code), &absinfo) == 0) {
+            ts_x_min = absinfo.minimum;
+            ts_x_max = absinfo.maximum;
+        }
+        if (ioctl(ts_fd, EVIOCGABS(abs_y_code), &absinfo) == 0) {
+            ts_y_min = absinfo.minimum;
+            ts_y_max = absinfo.maximum;
+        }
+        printf("I_InitInput: Touch range X=[%d,%d] Y=[%d,%d]\n",
+               ts_x_min, ts_x_max, ts_y_min, ts_y_max);
+    } else {
+        fprintf(stderr, "I_InitInput: No touchscreen found (keyboard-only mode)\n");
+    }
+
+    if (kb_fd < 0 && ts_fd < 0) {
+        fprintf(stderr, "I_InitInput: WARNING: No input devices found!\n"
+                "  Check /dev/input/event* permissions (need read access)\n");
+    }
+
+    I_AtExit(evdev_shutdown, true);
+
+    return 0;
+}
