From a7446782cbce7b2dcee941df8333d5db4c23efdc Mon Sep 17 00:00:00 2001
From: James Turton <james.turton@gmx.com>
Date: Thu, 19 Feb 2026 21:49:38 +0100
Subject: [PATCH] Add support for r528 msgbox and remoteproc

---
 drivers/mailbox/Kconfig     | 10 ++++++++++
 drivers/mailbox/Makefile    |  2 ++
 drivers/remoteproc/Kconfig  | 16 ++++++++++++++++
 drivers/remoteproc/Makefile |  1 +
 4 files changed, 29 insertions(+)

diff --git a/drivers/mailbox/Kconfig b/drivers/mailbox/Kconfig
index bc2e265cb..aea3dd4e1 100644
--- a/drivers/mailbox/Kconfig
+++ b/drivers/mailbox/Kconfig
@@ -277,6 +277,16 @@ config SUN6I_MSGBOX
 	  various Allwinner SoCs. This mailbox is used for communication
 	  between the application CPUs and the power management coprocessor.
 
+config SUNXI_R528_MSGBOX
+	tristate "Allwinner R528/D1/T113 Message Box"
+	depends on ARCH_SUNXI || COMPILE_TEST
+	depends on HAS_IOMEM
+	help
+	  Mailbox driver for the message box hardware found in Allwinner
+	  R528, D1, and T113 SoCs. This provides communication channels
+	  between the ARM CPU and the HiFi4 DSP core.
+	  Say Y here if you want to use the DSP on these SoCs.
+
 config SPRD_MBOX
 	tristate "Spreadtrum Mailbox"
 	depends on ARCH_SPRD || COMPILE_TEST
diff --git a/drivers/mailbox/Makefile b/drivers/mailbox/Makefile
index fc9376117..380eec732 100644
--- a/drivers/mailbox/Makefile
+++ b/drivers/mailbox/Makefile
@@ -57,6 +57,8 @@ obj-$(CONFIG_ZYNQMP_IPI_MBOX)	+= zynqmp-ipi-mailbox.o
 
 obj-$(CONFIG_SUN6I_MSGBOX)	+= sun6i-msgbox.o
 
+obj-$(CONFIG_SUNXI_R528_MSGBOX)	+= sunxi-r528-msgbox.o
+
 obj-$(CONFIG_SPRD_MBOX)		+= sprd-mailbox.o
 
 obj-$(CONFIG_QCOM_IPCC)		+= qcom-ipcc.o
diff --git a/drivers/remoteproc/Kconfig b/drivers/remoteproc/Kconfig
index 48845dc8f..29fab91e1 100644
--- a/drivers/remoteproc/Kconfig
+++ b/drivers/remoteproc/Kconfig
@@ -365,6 +365,22 @@ config XLNX_R5_REMOTEPROC
 
 	  It's safe to say N if not interested in using RPU r5f cores.
 
+config SUNXI_R528_HIFI4_REMOTEPROC
+	tristate "Allwinner R528/D1/T113 HiFi4 DSP remoteproc"
+	depends on ARCH_SUNXI || COMPILE_TEST
+	depends on REMOTEPROC
+	select MAILBOX
+	select SUNXI_R528_MSGBOX
+	help
+	  Say Y or M here to support the HiFi4 DSP found in Allwinner
+	  R528, D1, and T113 SoCs. This driver manages loading firmware,
+	  starting/stopping the DSP, and communicating via RPMsg.
+
+	  This is needed if you want to offload audio processing or other
+	  tasks to the DSP core.
+
+	  If unsure, say N.
+
 endif # REMOTEPROC
 
 endmenu
diff --git a/drivers/remoteproc/Makefile b/drivers/remoteproc/Makefile
index 91314a9b4..ed0959223 100644
--- a/drivers/remoteproc/Makefile
+++ b/drivers/remoteproc/Makefile
@@ -39,3 +39,4 @@ obj-$(CONFIG_STM32_RPROC)		+= stm32_rproc.o
 obj-$(CONFIG_TI_K3_DSP_REMOTEPROC)	+= ti_k3_dsp_remoteproc.o
 obj-$(CONFIG_TI_K3_R5_REMOTEPROC)	+= ti_k3_r5_remoteproc.o
 obj-$(CONFIG_XLNX_R5_REMOTEPROC)	+= xlnx_r5_remoteproc.o
+obj-$(CONFIG_SUNXI_R528_HIFI4_REMOTEPROC)	+= sunxi_r528_remoteproc.o
